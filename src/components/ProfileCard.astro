---
import Panel from './Panel.astro';
import { statusColors } from '../lib/discord';

interface Props {
	discordUserId: string;
	error?: string | null;
}

const { discordUserId, error = null } = Astro.props;

const statusColor = statusColors.offline;
---

<Panel title="image.png">
	<div class="pfp-wrapper" id="profile-card" data-discord-id={discordUserId}>
		{
			error ? (
				<p class="error-line">{error}</p>
			) : (
				<>
					<canvas id="ascii-canvas"></canvas>
					<div id="status-dot" class="status-dot" style={`background: ${statusColor}`} />
					<img
						id="pfp-src"
						crossorigin="anonymous"
						src=""
						alt=""
						width="256"
						height="256"
						hidden
					/>
				</>
			)
		}
	</div>
	<div id="discord-username" class="discord-name">@loading</div>
	<div class="discord-sub">on Discord</div>
</Panel>

<script>
	import {
		fetchLanyardPresence,
		getAvatarUrl,
		getDisplayName,
		statusColors,
		type LanyardPresence,
	} from '../lib/discord';
	import { initLanyard } from '../scripts/lanyard-client';
	import { initPfpCanvas, setPfpSource } from '../scripts/pfp-canvas';

	function applyPresence(presence: LanyardPresence) {
		const username = document.getElementById('discord-username');
		const statusDot = document.getElementById('status-dot');

		setPfpSource(getAvatarUrl(presence.discord_user));

		if (username) {
			username.textContent = `@${getDisplayName(presence.discord_user)}`;
		}

		if (statusDot) {
			statusDot.style.background =
				statusColors[presence.discord_status] ?? statusColors.offline;
		}
	}

	initPfpCanvas();

	const root = document.getElementById('profile-card');
	const id = root?.dataset.discordId;

	if (id) {
		fetchLanyardPresence(id)
			.then((presence) => {
				if (presence) applyPresence(presence);
			})
			.catch((err) => {
				const username = document.getElementById('discord-username');
				const message =
					err instanceof Error ? err.message : 'failed to load discord profile.';
				if (username) username.textContent = message;
			});

		initLanyard(id);
	}
</script>
